# ─── Telegram API (https://my.telegram.org → API development tools) ───
API_ID=0
API_HASH=your_api_hash_here

# ─── Бот (получить у @BotFather) ───
BOT_TOKEN=your_bot_token_here

# ─── Админы (Telegram ID, узнать у @userinfobot). Несколько через запятую ───
ADMIN_IDS=123456789

# ─── Лимиты безопасности (анти-бан, на каждый аккаунт в сутки) ───
MAX_INVITES_PER_DAY=40
MAX_MESSAGES_PER_DAY=30
FLOOD_COOLDOWN=3600

# ─── Задержки между действиями, "мин-макс" секунд ───
DEFAULT_DELAY_INVITE=20-45
DEFAULT_DELAY_SEND=15-40

# ─── Опционально: персистентный FSM через Redis ───
# REDIS_URL=redis://localhost:6379/0

# ─── Логирование ───
LOG_LEVEL=INFO
